# Environment Configuration
# =================================
# Copy this file to .env and fill in the values
#
# Minimum required to run the current version end-to-end:
# - DATABASE_URL
# - BETTER_AUTH_SECRET
# - STORAGE_PROVIDER (for file storage)
#
# We provide acceptable default values for local development.
# Any value left blank MUST be set manually in your own .env.dev.
# Optional variables are listed in their sections below.

# Project
PROJECT_NAME=project
DOCKER_TAG=latest
DOCKER_TARGET=development
TARGETOS=linux       # Only used to build production images
TARGETARCH=amd64     # Only used to build production images
PLATFORM=linux/amd64 # amd64 (intel) | arm64 (apple silicon)

# Application URLs
ORIGIN=http://127.0.0.1:3000
GO_API_URL=http://${PROJECT_NAME}-back:8080

# Database (Local postgres for development, Neon for preview and production)
# Required: DATABASE_URL.
# Expected shape: postgresql://user:password@ep-example.us-east-2.aws.neon.tech/neondb?sslmode=require
POSTGRES_DB=${PROJECT_NAME}
POSTGRES_USER=op://saas_seed/postgres/username
POSTGRES_PASSWORD=op://saas_seed/postgres/password
#  Required.
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?sslmode=disable

# Authentication (Better Auth)
# Required. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=op://saas_seed/better_auth/secret
JWT_ISSUER=${PROJECT_NAME}
JWT_AUDIENCE=${PROJECT_NAME}-api

# Encryption (for storing user API keys)
# Required. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=op://saas_seed/encryption_key/password

# LLM Providers (Gemini default)
# RequireDefault: LLM_PROVIDER + API_KEY + MODEL for the provider you want to use.
LLM_PROVIDER=google

# Optional LLM providers
OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
GROQ_API_KEY=
GROQ_MODEL=

# Storage: fs (local filesystem) | minio (S3-compatible)
STORAGE_PROVIDER=fs
# minio
# MINIO_ENDPOINT=http://minio:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=bucket
# MINIO_USE_SSL=false
# MINIO_PUBLIC_BASE_URL=

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Payments (optional)
# Supported providers: polar | (empty for none)
PAYMENT_PROVIDER=polar
PAYMENT_SUCCESS_URL=http://127.0.0.1:3000/success
PAYMENT_CANCEL_URL=http://127.0.0.1:3000/pricing
# POLAR payment provider configuration
POLAR_ACCESS_TOKEN=op://saas_seed/polar/access_token
POLAR_SERVER=sandbox
POLAR_WEBHOOK_SECRET=op://saas_seed/polar/webhook_secret=
